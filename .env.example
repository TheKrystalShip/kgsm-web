# ---------------------------------------------------------------------------
# Krystal Control Panel — frontend environment
# Copy this file to `.env.local` and fill in once the backend is reachable.
# ---------------------------------------------------------------------------

# ORIGIN of a kgsm-api host — scheme + host + port, NO path. The client appends
# /api/v1 itself, so do NOT include it here. This is an OPTIONAL single-host seed:
# if left blank, the app starts on the connect screen and you add a host there.
# Example: http://127.0.0.1:8080   (or https://your-host)
#
# SAME-ORIGIN deployment: set this to "self" when kgsm-api serves this bundle at /
# and the API under /api/v1 on the SAME host (one domain, no CORS). The seed then
# resolves to the origin that served the page, so the bundle carries no baked URL.
# (The kgsm-api deploy builds the bundle with VITE_API_BASE=self automatically.)
VITE_API_BASE=

# Realtime WebSocket origin (optional). If blank it's derived from VITE_API_BASE
# (http→ws) as <origin>/api/v1/stream. Override only if the socket lives elsewhere.
# Example: wss://your-host/api/v1/stream
VITE_WS_BASE=
