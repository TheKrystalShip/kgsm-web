@page "/"
@rendermode InteractiveServer

@using System.Collections
@using TheKrystalShip.KGSM.Lib
@using TheKrystalShip.KGSM.Web.Services

@inject KgsmEventState eventState
@inject KgsmInterop interop

<PageTitle>Home</PageTitle>

<h1>KGSM Instances</h1>

<button class="btn btn-primary" @onclick="@(e => eventState.LoadInstances())">Reload</button>

<table class="table">
  <thead>
    <tr>
      <th>Name</th>
      <th>Status</th>
      <th>Action</th>
    </tr>
  </thead>
  <tbody>
    @foreach (Instance instance in eventState.Instances.Values)
    {
      <tr>
        <td>@instance.Name</td>
        <td>@instance.Status</td>
        <td>
          @if (instance.Status == InstanceStatus.Inactive)
          {
            <button class="btn btn-success" @onclick="@(_ => interop.Start(@instance.Name))">Start</button>
          }
          else
          {
            <button class="btn btn-danger" @onclick="@(_ => interop.Stop(@instance.Name))">Stop</button>
          }
        </td>
      </tr>
    }
  </tbody>
</table>

<h2>Action log</h2>

@foreach (string action in eventState.Events)
{
  <p>@action</p>
}

@code {
  protected override void OnInitialized()
  {
    eventState.OnChange += async () => await InvokeAsync(StateHasChanged);
  }
}
