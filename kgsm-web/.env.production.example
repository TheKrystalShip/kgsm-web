# KGSM Web Admin Panel Production Environment Configuration

# Auth0 Configuration
# Replace these with your actual Auth0 application values
REACT_APP_AUTH0_DOMAIN=your-auth0-domain.auth0.com
REACT_APP_AUTH0_CLIENT_ID=your-auth0-client-id
REACT_APP_AUTH0_AUDIENCE=https://kgsm-api/

# API URL - In production, this should be a relative path if served from the same domain
REACT_APP_API_URL=/api
