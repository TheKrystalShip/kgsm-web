/kgsm-web/.env.local
/kgsm-web/.env.development.local
/kgsm-web/.env.test.local
/kgsm-web/.env.production.local
.DS_Store

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Logs
logs
*.log

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

